# =============================================================
# DLC OS — Environment Configuration (example)
# Copy to .env and fill in. NEVER commit your real .env.
# =============================================================

# ---- Core ----
APP_ENV=development              # development | staging | production
APP_SECRET_KEY=change-me-please
APP_BASE_URL=http://localhost:8000
FRONTEND_BASE_URL=http://localhost:3000

# ---- Database ----
DATABASE_URL=postgresql://dlcos:dlcos@localhost:5432/dlcos
REDIS_URL=redis://localhost:6379/0

# ---- Celery (background jobs) ----
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ---- Authentication ----
JWT_SECRET=change-me
JWT_ACCESS_TTL_MINUTES=15
JWT_REFRESH_TTL_DAYS=30

# ---- AI Layer ----
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
LLM_DEFAULT_PROVIDER=anthropic     # anthropic | openai | local
LLM_DEFAULT_MODEL=claude-opus-4-8
LOCAL_LLM_BASE_URL=http://localhost:11434   # e.g. Ollama
VECTOR_STORE_URL=                  # e.g. pgvector (uses DATABASE_URL) or external

# ---- Channels ----
DISCORD_BOT_TOKEN=
DISCORD_CLIENT_ID=
DISCORD_GUILD_ID=
TELEGRAM_BOT_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_WEBHOOK_VERIFY_TOKEN=

# ---- Payments ----
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
SQUARE_ACCESS_TOKEN=
CRYPTO_PROVIDER_API_KEY=

# ---- Shipping ----
SHIPPING_PROVIDER_API_KEY=         # e.g. EasyPost / Shippo

# ---- Marketing / Messaging ----
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMS_PROVIDER_API_KEY=              # e.g. Twilio

# ---- Observability ----
SENTRY_DSN=
OTEL_EXPORTER_OTLP_ENDPOINT=
LOG_LEVEL=info
